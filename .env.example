# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
DEBUG=true
API_KEY=neuromem-dev-key-change-me

# ── LLM (Provider-Agnostic via OpenAI-compatible API) ────────────────
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
WORKING_MEMORY_TTL_SECONDS=7200
WORKING_MEMORY_MAX_TURNS=12

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql://neuromem:neuromem@localhost:5432/neuromem
EPISODIC_MEMORY_TTL_DAYS=30

# ── Qdrant ────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=neuromem_semantic
QDRANT_API_KEY=

# ── Neo4j (Knowledge Graph) ──────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neuromem123

# ── Embeddings ────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cpu

# ── Re-Ranking ────────────────────────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Cognitive Scoring ─────────────────────────────────────────────────
CONSOLIDATION_DECAY_THRESHOLD=0.2
SURPRISE_THRESHOLD=0.15
MEMORY_TOKEN_BUDGET=2000

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
